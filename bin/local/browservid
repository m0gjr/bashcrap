#!/bin/bash

get_socks_host(){
	mullvad-confgen $1 | grep socks_name | cut -d'"' -f4
}

hostfile=$XDG_RUNTIME_DIR/browservid-socks
trap "rm -r $ytdl_dir" SIGTERM SIGINT

export ytdl_dir=$(mktemp -d /tmp/ytdl.XXXX)

if [ -n "$proxyvid" ]
then
	country="$(shuf -n1 -e us se)"
else
	country="gb"
fi

if [ -f "$hostfile" ]
then
	export socks_host="$(head -n1 "$hostfile")"
else
	export socks_host="$(get_socks_host)"
fi

get_socks_host "$country" > "$hostfile" &

export socks_port=1080
export listen_port=$(( 20000 + $RANDOM))

echo "$socks_host"

socks-http-proxy& pid=$!

export http_proxy="http://localhost:$listen_port"

ytdlops="--script-opts-append=ytdl_hook-try_ytdl_first=yes --script-opts-append=ytdl_hook-ytdl_path=ytdl-term"

if tty | grep -q '^/dev/pts/'
then
	o="--fs=no $ytdlops"
else
	o="--terminal=no $ytdlops"
fi

if [ -z "$fallback" ]
then
	s="height:720"

	mpv ${opts:-$o} --ytdl-raw-options-append=format-sort="${sort:-$s}" --ytdl-format="${format:-$f}" "$1"
else
	o="$o"
	s="height:720,proto:m3u8"
	f="bv+ba"

	urlfile=$ytdl_dir/url
	audiofile=$ytdl_dir/audio

	mkfifo $audiofile

	ytdl-term "$1" -f "$f" -S "$s" --js-runtimes=node -g > $urlfile
	yt-dlp -o - "$(tail -n1 $urlfile)" > $audiofile &
	yt-dlp -o - "$(head -n1 $urlfile)" | mpv ${opts:-$o} --audio-file=$audiofile -
	rm "$audiofile"
fi

[ -n "$pid" ] && kill $pid

rm -r $ytdl_dir

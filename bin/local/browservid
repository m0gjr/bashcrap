#!/bin/bash

get_socks_host(){
	mullvad-confgen $1 | grep socks_name | cut -d'"' -f4
}

hostfile=$XDG_RUNTIME_DIR/browservid-socks
trap "rm -r $ytdl_dir" SIGTERM SIGINT

export ytdl_dir=$(mktemp -d /tmp/ytdl.XXXX)

if [ -n "$proxyvid" ]
then
	country="$(shuf -n1 -e us se)"
else
	country="gb"
fi

if [ -f "$hostfile" ]
then
	export socks_host="$(head -n1 "$hostfile")"
else
	export socks_host="$(get_socks_host)"
fi

get_socks_host "$country" > "$hostfile" &

export socks_port=1080
export listen_port=$(( 20000 + $RANDOM))

echo "$socks_host"

socks-http-proxy& pid=$!

export http_proxy="http://localhost:$listen_port"

ytdlops="--script-opts-append=ytdl_hook-try_ytdl_first=yes"

if tty | grep -q '^/dev/pts/'
then
	o="--fs=no $ytdlops"
else
	o="--terminal=no $ytdlops"
fi

s="height:720"

if [ -z "$fallback" ]
then
	mpv ${opts:-$o} --script-opts-append=ytdl_hook-ytdl_path=ytdl-term --ytdl-raw-options-append=format-sort="${sort:-$s}" --ytdl-format="${format:-$f}" "$@"
else
	mkfifo $ytdl_dir/video
	mkfifo $ytdl_dir/audio


	ytdl-term --js-runtimes=node -S "$s" -f "bv*" -o $ytdl_dir/video --write-sub --sub-format srt "$@" &
	yt-dlp --js-runtimes=node -S "$s" -f "ba" -o $ytdl_dir/audio "$@" &

	mpv ${opts:-$o} --force-window=yes --audio-file=$ytdl_dir/audio $ytdl_dir/video

	rm $ytdl_dir/video
	rm $ytdl_dir/audio
fi

[ -n "$pid" ] && kill $pid

rm -r $ytdl_dir
